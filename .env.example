# Vercel / local production API keys
GEMINI_API_KEY="your_gemini_api_key_here"

# Supabase frontend values
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# Supabase backend values
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# Use API-backed provider in production
VITE_USE_API_PROVIDER="true"

# Public app URL used for OAuth redirects in production
VITE_PUBLIC_APP_URL="https://your-vercel-domain.vercel.app/"

# Keep guest mode disabled in production
VITE_ALLOW_GUEST_ACCESS="false"

# Optional server-side reference
APP_URL="https://your-vercel-domain.vercel.app"
